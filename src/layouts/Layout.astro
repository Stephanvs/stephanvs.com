---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Home',
	description = 'Independent software architect & developer'
} = Astro.props;
const path = Astro.url.pathname;
const pageTitle = `${title} | Stephan van Stekelenburg`;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" href="/favicon.ico" sizes="any" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
	</head>
	<body class="bg-stone-100 px-5 font-sans text-stone-900 antialiased selection:bg-orange-200 md:px-12">
		<header class="mx-auto flex max-w-7xl flex-col items-start justify-between gap-5 border-b border-stone-900 py-5 sm:min-h-20 sm:flex-row sm:items-center">
			<a href="/" class="font-serif text-2xl font-semibold leading-none no-underline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-orange-700">
				<span class="text-orange-700">S/</span> Stephan van Stekelenburg
			</a>
			<nav class="w-full overflow-x-auto sm:w-auto" aria-label="Main navigation">
				<ul class="flex list-none gap-6 pb-1 sm:pb-0">
					<li>
						<a
							href="/"
							class:list={[
								'font-mono text-xs uppercase tracking-widest no-underline transition-colors hover:text-orange-700 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-orange-700',
								{ 'text-orange-700': path === '/' }
							]}>Home</a>
					</li>
					<li>
						<a
							href="/blog"
							class:list={[
								'font-mono text-xs uppercase tracking-widest no-underline transition-colors hover:text-orange-700 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-orange-700',
								{ 'text-orange-700': path.startsWith('/blog') }
							]}>Blog</a>
					</li>
					<li>
						<a
							href="/work"
							class:list={[
								'font-mono text-xs uppercase tracking-widest no-underline transition-colors hover:text-orange-700 focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-orange-700',
								{ 'text-orange-700': path.startsWith('/work') }
							]}>Work</a>
					</li>
				</ul>
			</nav>
		</header>
		<main class="mx-auto max-w-7xl"><slot /></main>
		<footer class="mx-auto mt-24 flex max-w-7xl flex-col justify-between gap-3 border-t border-stone-900 py-8 font-mono text-xs text-stone-500 sm:flex-row">
			<span>&copy; {new Date().getFullYear()} Stephan van Stekelenburg</span>
			<span>Software architecture / distributed systems / engineering</span>
		</footer>
	</body>
</html>
