---
import { getCollection } from 'astro:content';
import Card from '../../components/Card.astro';
import Layout from '../../layouts/Layout.astro';
import { contentSlug } from '../../lib/content';

const works = await getCollection('work');
---

<Layout title="Work" description="Selected software architecture and engineering work.">
  <section class="py-16 md:py-20">
    <h1 class="mb-10 font-serif text-6xl leading-none tracking-tighter md:text-8xl">Work</h1>
    <div class="grid grid-cols-1 border-t border-stone-900 md:grid-cols-2 md:gap-x-8">
      {works.map((item) => (
        <Card
          href={`/work/${contentSlug(item.id)}/`}
          image={item.data.image}
          meta="Case study"
          title={item.data.title}
          excerpt={item.data.excerpt}
        />
      ))}
    </div>
  </section>
</Layout>
